# Supabase (required for admin and loading articles from DB)
# Copy to .env.local and fill in your project values from https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# For image uploads: create bucket "article-images" (public) in Dashboard > Storage,
# then run supabase/migrations/002_storage_article_images.sql for upload policies.
